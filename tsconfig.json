{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "lib": ["ES2022", "dom"],
        "types": ["react"],
        "isolatedModules": true,
        "resolveJsonModule": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "include": ["src"],
    "exclude": [
        "node_modules",
        "dist",
        "playground",
        "**/*.test.ts",
        "**/*.test.tsx"
    ]
}
