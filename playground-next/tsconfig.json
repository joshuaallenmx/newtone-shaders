{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "lib": ["ES2022", "dom"],
        "isolatedModules": true,
        "noEmit": true,
        "types": ["vite/client", "node"],
        "paths": {
            "@newtonedev/shaders": ["../src/index.ts"]
        }
    },
    "include": ["./**/*.ts", "./**/*.tsx"]
}
